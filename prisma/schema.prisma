generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id          String @id @default(cuid())
  name        String
  location    String
  fees        Int
  rating      Float
  overview    String
  stream      String
  courseLevel String

  savedBy    SavedCollege[]
  comparedBy ComparedCollege[]

  createdAt DateTime @default(now())
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  savedColleges    SavedCollege[]
  comparedColleges ComparedCollege[]

  createdAt DateTime @default(now())
    accounts Account[]
  sessions Session[]
}

model Account {
  id                 String @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model SavedCollege {
  id String @id @default(cuid())

  userId    String
  collegeId String

  user    User    @relation(fields: [userId], references: [id])
  college College @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}

model ComparedCollege {
  id String @id @default(cuid())

  userId    String
  collegeId String

  user    User    @relation(fields: [userId], references: [id])
  college College @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}
